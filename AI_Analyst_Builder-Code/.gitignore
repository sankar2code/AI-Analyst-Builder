# Intermediate working files
working/

# Output files (student-generated, not committed)
outputs/

# Environment and secrets
.env
.env.*
*.key
*.pem
credentials.json
client_secret*.json
service_account*.json
*.credential
*.token

# Claude Code config (user-specific)
.claude/mcp.json
.claude/settings.local.json
.mcp.json

# Connection templates (live copies with credentials)
connection_templates/*.yaml
!connection_templates/*.yaml.example

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor and IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.settings/
.classpath

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
.ipynb_checkpoints/
*.ipynb_checkpoints
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/

# Node.js
node_modules/
package-lock.json
yarn.lock
.npm/

# Data files -- block all CSVs by default
data/**/*.csv
data/**/*.duckdb
data/**/*.parquet
*.xlsx


# Zillow (should never exist, belt-and-suspenders)
data/zillow/

# Generated slide/deck artifacts
**/*.marp.pdf
**/slides_*.pdf
**/slides_*.html

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Knowledge system -- user-specific files
.knowledge/active.yaml
.knowledge/setup-state.yaml
.knowledge/user/
.knowledge/datasets/*/

# Analyses archive (user-generated content ignored, seed files kept)
.knowledge/analyses/*
!.knowledge/analyses/index.yaml
!.knowledge/analyses/_schema.yaml
!.knowledge/analyses/_patterns.yaml

# Global observations (user-generated content ignored, seed files kept)
.knowledge/global/*
!.knowledge/global/cross_dataset_observations.yaml

# Archives
*.zip
*.tar.gz
*.rar
*.7z
